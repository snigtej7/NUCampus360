# ── NUCampus360 Backend Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Your Gemini API key (get one at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Comma-separated list of allowed frontend origins (no trailing slashes)
# In production, replace with your actual Vercel URL
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-frontend-url.vercel.app

# Port for local development (Render uses its own PORT env automatically)
PORT=3001

# Environment
NODE_ENV=development
